# 複製為 .env 並依實際環境調整；.env 本身已在 .gitignore 中，不會被提交。

# --- 資料庫（compose 內預設連到 postgres service）---
DATABASE_URL=postgresql+psycopg://stocklab:stocklab@postgres:5432/stocklab

# --- Telegram 通知（docs/design.md §8；失敗告警與每日訊號用）---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 應用一般設定 ---
APP_ENV=development
TIMEZONE=Asia/Taipei
